MOCK_AUTH=true


# ==================== CONFIGURACIÓN THEREFORE ====================
THEREFORE_BASE_URL=https://therefore.urovesa.com:443/theservice/v0001/restun
THEREFORE_USERNAME=URO\thereforeqs
THEREFORE_PASSWORD=DST981$$89OOd
THEREFORE_TENANT=nombre_tenant

# ==================== CONFIGURACI"N LDAP/ACTIVE DIRECTORY ====================
# URL del servidor LDAP (usar ldaps:// para conexi"n segura)
LDAP_URL=ldaps://ad.urovesa.com:636

# Base DN del dominio (ej: dc=urovesa,dc=com)
LDAP_BASE_DN=dc=urovesa,dc=com

# Formato de Distinguished Name para usuarios
# {username} ser" reemplazado por el nombre de usuario
# {baseDN} ser" reemplazado por LDAP_BASE_DN
LDAP_USER_DN_FORMAT=CN={username},CN=Users,{baseDN}

# Filtro de b"squeda LDAP para encontrar usuarios
# {username} ser" reemplazado por el nombre de usuario
LDAP_SEARCH_FILTER=(sAMAccountName={username})

# Cuenta t"cnica de servicio con permisos para autenticaci"n y cambio de contrase"as
# IMPORTANTE: Preguntar al equipo de backend por estos valores reales
LDAP_ADMIN_DN=CN=svc_ldap_api,CN=Users,DC=urovesa,DC=com
LDAP_ADMIN_PASSWORD=contraseña_segura_aqui

# Configuraci"n de certificados SSL
# Si es false, no se verificar"n certificados (solo para desarrollo)
LDAP_REJECT_UNAUTHORIZED=true

# ==================== CONFIGURACI"N EMPLEADOS ====================
# URL del endpoint que devuelve la lista de empleados con acceso al portal
# Este endpoint debe aceptar el par"metro "consulta=empleados"
EMPLEADOS_API_URL=http://10.10.33.5:8090/qs_service/portal_empleado/devuelve_datos


EMPLEADOS_API_KEY=bd06caaa-c3a7-4c55-8e51-3f2s50d77331
